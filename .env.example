# Railway PostgreSQL — automatically set when you add the PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Fernet symmetric encryption key for garth tokens stored in DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# Public URL of the deployed app — set this after first Railway deploy
# Used to generate the MCP connector URLs shown to users
APP_BASE_URL=https://garminfit-connector.railway.app

# Port — automatically set by Railway, leave as-is
PORT=8000
